<?xml version="1.0" encoding="UTF-8"?>
<!--
  简单 SKILL.xml 模板
  
  用途：最小化 Skill 工作流模板，适合快速创建单一功能的 Skill
  约束：遵循 SKILL.xml 规范，禁止使用 dispatch-to-worker
-->
<workflow id="[your-skill-id]" 
          version="1.0"
          status="pending"
          desc="[你的 Skill 描述，简要说明这个 Skill 的功能]">
  
  <!--
  == Block Types ==
  input   : 工作流输入参数（required=必填, default=默认值）
  output  : 工作流输出结果（from=数据来源变量）
  task    : 执行动作（action: run-skill | run-script）
  gateway : 条件分支/门禁（mode: exclusive | guard）
  event   : 日志/确认（action: log）
  error-handler : 异常处理（try > catch）
  checkpoint : 持久化里程碑（name=检查点名）
  == Field ==
  field   : 参数/变量/输出（name=参数名, var=绑定变量, value=值）
  -->
  
  <!-- ==================== 输入参数定义 ==================== -->
  <!-- 提示：定义 Skill 需要的输入参数，类似函数签名 -->
  <block type="input" id="I1" desc="工作流输入参数">
    <!-- [必填参数示例] -->
    <field name="[param1]" required="true" type="string" desc="[参数1描述]"/>
    <field name="[param2]" required="true" type="string" desc="[参数2描述]"/>
    <!-- [可选参数示例] -->
    <field name="[param3]" required="false" type="string" default="[默认值]" desc="[参数3描述]"/>
  </block>
  
  <!-- ==================== 执行序列 ==================== -->
  <sequence id="S1" name="主执行序列" status="pending" desc="Skill 核心执行逻辑">
    
    <!-- Step 1: 参数校验（可选） -->
    <!-- 提示：使用 gateway guard 模式校验必填参数 -->
    <block type="gateway" id="G1" mode="guard" 
            test="${[param1]} != ''" 
            fail-action="stop"
            desc="参数非空校验">
      <field name="message">[参数1] 不能为空</field>
    </block>
    
    <!-- Step 2: 执行主要任务 -->
    <!-- 提示：使用 run-skill 调用其他 Skill，或使用 run-script 执行脚本 -->
    <block type="task" id="B1" action="run-script" status="pending" desc="[执行步骤描述]">
      <field name="command">[命令]</field>
      <field name="arg">${[param1]}</field>
      <field name="output" var="[resultVar]"/>
    </block>
    
    <!-- Step 3: 处理结果（可选） -->
    <block type="task" id="B2" action="run-script" status="pending" desc="[处理步骤描述]">
      <field name="command">[处理命令]</field>
      <field name="arg">${[resultVar]}</field>
      <field name="output" var="[finalResult]"/>
    </block>
    
    <!-- Step 4: 记录日志（可选） -->
    <block type="event" id="E1" action="log" level="info" desc="记录完成">
      [操作完成描述]: ${[finalResult]}
    </block>
    
    <!-- Checkpoint: 标记完成（可选） -->
    <block type="checkpoint" id="CP1" name="[checkpoint_name]" desc="[检查点描述]">
      <field name="file" value="[检查点文件路径]"/>
      <field name="passed" value="true"/>
    </block>
    
  </sequence>
  
  <!-- ==================== 输出结果定义 ==================== -->
  <!-- 提示：定义 Skill 的输出结果，类似函数返回值 -->
  <block type="output" id="O1" desc="工作流输出结果">
    <field name="[output1]" from="${[finalResult].[property]}" type="string" desc="[输出1描述]"/>
    <field name="[output2]" from="${[resultVar].[property]}" type="array" desc="[输出2描述]"/>
    <field name="success" from="${[finalResult].success}" type="boolean" desc="是否成功"/>
  </block>

</workflow>
