  "template_rules": {
    "language_adaptation": {
      "description": "All templates must support language parameter",
      "valid_languages": ["zh", "en", "ja", "ko", "fr", "de", "es"],
      "default": "zh"
    },
    "source_traceability": {
      "description": "All generated documents must include source file references",
      "required_blocks": [
        "Referenced Files block at document start",
        "Diagram Source after each Mermaid diagram",
        "Section Source at end of major sections"
      ]
    },
    "mermaid_compatibility": {
      "description": "All diagrams must follow mermaid-rule.md guidelines",
      "reference": "speccrew-workspace/docs/rules/mermaid-rule.md"
    }
  },
  "versioning": {
    "strategy": "semantic_versioning",
    "format": "major.minor.patch",
    "update_triggers": [
      "Template structure changes",
      "New placeholders added",
      "Section requirements changed"
    ]
  }
}
