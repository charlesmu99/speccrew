{
  "version": "1.0.0",
  "description": "Document templates metadata for knowledge generation across all skills",
  "last_updated": "2026-03-23",
  "templates": {
    "module_overview": {
      "name": "MODULE-OVERVIEW-TEMPLATE",
      "file_name": "MODULE-OVERVIEW-TEMPLATE.md",
      "path": "speccrew-workspace/docs/templates/MODULE-OVERVIEW-TEMPLATE.md",
      "description": "Template for generating initial module overview with feature list",
      "used_by": ["speccrew-knowledge-module-analyze"],
      "applies_to": {
        "system_types": ["ui", "api"],
        "platforms": ["web", "mobile", "backend", "desktop", "api"]
      },
      "output_pattern": "{module_name}-overview.md",
      "sections": [
        {
          "name": "Module Basic Info",
          "required": true,
          "description": "Module name, purpose, and domain"
        },
        {
          "name": "Feature List",
          "required": true,
          "description": "Table of features with API endpoints and status"
        },
        {
          "name": "Architecture Overview",
          "required": false,
          "description": "Module structure diagram and dependencies"
        },
        {
          "name": "Data Model",
          "required": false,
          "description": "Entity relationships and key entities"
        },
        {
          "name": "API Summary",
          "required": false,
          "description": "Summary of all APIs (marked as TBD in initial version)"
        },
        {
          "name": "Business Rules",
          "required": false,
          "description": "Key business rules (marked as TBD in initial version)"
        }
      ],
      "placeholders": [
        "{{ModuleName}}",
        "{{ModulePurpose}}",
        "{{PlatformName}}",
        "{{TechStack}}",
        "{{FeatureList}}",
        "{{ArchitectureDiagram}}"
      ]
    },
    "feature_detail": {
