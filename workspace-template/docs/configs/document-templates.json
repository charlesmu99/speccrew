      "placeholders": [
        "{{FeatureName}}",
        "{{ModuleName}}",
        "{{ApiMethod}}",
        "{{ApiPath}}",
        "{{RequestDto}}",
        "{{ResponseDto}}",
        "{{ValidationRules}}",
        "{{BusinessRules}}",
        "{{SourceFiles}}"
