        {
          "name": "Feature Overview",
          "required": true,
          "description": "Feature name, description, and purpose"
        },
        {
          "name": "API Specification",
          "required": true,
          "description": "HTTP method, path, request/response DTOs"
        },
        {
          "name": "Validation Rules",
          "required": false,
          "description": "Input validation constraints"
        },
        {
          "name": "Business Rules",
          "required": false,
          "description": "Business logic and constraints"
