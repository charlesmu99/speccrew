{
  "version": "1.0.0",
  "description": "Feature granularity rules for determining how to split features in module analysis",
  "last_updated": "2026-03-23",
  "granularity_levels": {
    "simple": {
      "name": "Simple",
      "criteria": {
        "api_endpoints": {
          "max": 3,
          "description": "Less than or equal to 3 API endpoints"
        },
        "business_flow": {
          "complex": false,
          "description": "No complex business flow or multi-step processes"
        },
        "data_entities": {
          "max": 2,
          "description": "Involves at most 2 related data entities"
        },
        "user_interactions": {
          "max": 3,
          "description": "For UI: at most 3 major user interactions"
        }
      },
      "splitting_strategy": {
        "action": "merge",
        "description": "Merge all related operations into a single feature document",
        "document_structure": "Single document covering all CRUD operations"
      },
      "examples": [
        {
          "scenario": "Data Dictionary Management",
          "endpoints": ["GET /dicts", "POST /dicts", "DELETE /dicts/{id}"],
          "result": "Single feature: data-dictionary-management.md"
        },
        {
          "scenario": "Simple Configuration",
          "endpoints": ["GET /config", "PUT /config"],
          "result": "Single feature: configuration-management.md"
        }
      ]
    },
    "medium": {
      "name": "Medium",
      "criteria": {
        "api_endpoints": {
          "min": 3,
          "max": 8,
          "description": "Between 3 to 8 API endpoints"
        },
        "business_flow": {
          "complex": "moderate",
          "description": "Independent business scenarios with clear boundaries"
        },
        "data_entities": {
          "min": 2,
          "max": 4,
          "description": "Involves 2-4 related data entities"
        },
        "user_interactions": {
          "min": 3,
          "max": 6,
          "description": "For UI: 3-6 major user interactions"
        }
      },
      "splitting_strategy": {
        "action": "split_by_operation",
        "description": "Split by operation type or independent business scenario",
        "document_structure": "Separate documents for different operations"
      },
      "examples": [
        {
          "scenario": "User Management",
          "endpoints": [
            "POST /users",
            "GET /users",
            "GET /users/{id}",
            "PUT /users/{id}",
            "DELETE /users/{id}",
            "PATCH /users/{id}/status"
          ],
          "result": [
            "user-crud.md (create, read, update, delete)",
            "user-status-management.md (status operations)"
          ]
        },
        {
          "scenario": "Product Catalog",
          "endpoints": [
            "GET /products",
            "POST /products",
            "PUT /products/{id}",
            "GET /categories",
            "POST /categories"
          ],
          "result": [
            "product-management.md",
            "category-management.md"
          ]
        }
      ]
    },
    "complex": {
      "name": "Complex",
      "criteria": {
        "api_endpoints": {
          "min": 8,
          "description": "More than 8 API endpoints"
        },
        "business_flow": {
          "complex": true,
          "description": "Multiple business scenarios with complex workflows"
        },
        "data_entities": {
          "min": 4,
          "description": "Involves 4+ related data entities"
        },
        "user_interactions": {
          "min": 6,
          "description": "For UI: 6+ major user interactions"
        },
        "state_machines": {
          "present": true,
          "description": "Contains state transitions (e.g., order status, approval flow)"
        }
      },
      "splitting_strategy": {
        "action": "split_by_scenario",
        "description": "Split by distinct business scenario or subdomain",
        "document_structure": "Separate documents for each business scenario"
      },
      "examples": [
        {
          "scenario": "Payment System",
          "endpoints": [
            "POST /orders",
            "GET /orders",
            "POST /payments",
            "GET /payments",
            "POST /refunds",
            "GET /refunds",
            "POST /chargebacks",
            "POST /webhooks"
          ],
          "result": [
            "payment-order-management.md",
            "payment-processing.md",
            "payment-refund-management.md",
            "payment-security-mechanism.md",
            "payment-webhook-handling.md"
          ]
        },
        {
          "scenario": "E-commerce Order System",
          "features": [
            "Order Creation Flow",
            "Order Status Management",
            "Payment Integration",
            "Shipping & Logistics",
            "Return & Refund",
            "Order Analytics"
          ],
          "result": [
            "order-creation.md",
            "order-status-management.md",
            "order-payment.md",
            "order-shipping.md",
            "order-return-refund.md",
            "order-analytics.md"
          ]
        }
      ]
    }
  },
  "decision_matrix": {
    "description": "Decision tree for determining granularity level",
    "steps": [
      {
        "step": 1,
        "question": "Count total API endpoints (or UI interactions)",
        "branches": {
          "<= 3": "Simple",
          "3-8": "Go to step 2",
          "> 8": "Go to step 3"
        }
      },
      {
        "step": 2,
        "question": "Are there independent business scenarios?",
        "condition": "3-8 endpoints",
        "branches": {
          "Yes": "Medium - split by scenario",
          "No": "Medium - split by operation type"
        }
      },
      {
        "step": 3,
        "question": "Are there multiple distinct business domains?",
        "condition": "> 8 endpoints",
        "branches": {
          "Yes": "Complex - split by business scenario",
          "No": "Complex - analyze workflow complexity"
        }
      }
    ]
  },
  "ui_specific_rules": {
    "description": "Additional rules for UI-based modules",
    "feature_identification": {
      "page_based": "Each distinct page/screen = potential feature",
      "interaction_based": "Major user interaction flows = separate features",
      "modal_based": "Complex modal workflows may be separate features"
    },
    "splitting_criteria": {
      "simple": "Single page with basic CRUD",
      "medium": "Page with multiple tabs or sections",
      "complex": "Multi-step wizard or workflow"
    }
  },
  "api_specific_rules": {
    "description": "Additional rules for API-based modules",
    "feature_identification": {
      "endpoint_based": "Each public API endpoint = potential feature",
      "resource_based": "Group by resource/entity type",
      "operation_based": "Group by operation type (CRUD)"
    },
    "splitting_criteria": {
      "controller_level": "Group endpoints by controller/resource",
      "business_scenario": "Group by business use case",
      "complexity": "Consider validation and business rule complexity"
    }
  },
  "naming_conventions": {
    "feature_name_format": "{action}-{resource}",
    "examples": {
      "valid": [
        "create-order",
        "list-users",
        "get-user-detail",
        "update-product",
        "delete-category",
        "approve-workflow"
      ],
      "invalid": [
        "CreateOrder",
        "create_order",
        "order-creation-api",
        "handleUserManagement"
      ]
    },
 "overview_suffix": "-overview",
    "feature_directory": "features/"
  },
  "document_structure": {
    "simple": {
      "files": 1,
      "naming": "{module-name}-overview.md",
      "content": "All operations in single document with subsections"
    },
    "medium": {
      "files": "2-4",
      "naming": [
        "{module-name}-overview.md",
        "features/{operation-type}.md"
      ]
    },
    "complex": {
      "files": "4+",
      "naming": [
        "{module-name}-overview.md",
        "features/{business-scenario}.md"
      ]
    }
  },
  "validation_checklist": {
    "before_splitting": [
      "Count total API endpoints or UI interactions",
      "Identify data entities involved",
      "Map business scenarios and workflows",
      "Check for state machines or complex flows"
    ],
    "after_splitting": [
      "Each feature has clear, single responsibility",
      "Feature names follow naming conventions",
      "No duplicate content across features",
      "All endpoints/interactions are covered"
    ]
  }
}
